title: "HydroStat Data Explorer"
type: software
authors:
  - family-names: "Fernandes"
    given-names: "Wilson"
    orcid: "https://orcid.org/0000-0002-9731-2320"
repository-code: "https://github.com/hydrostat/hydrostat-data-explorer"
